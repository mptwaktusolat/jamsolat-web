<section id="prayer-list" aria-label="Prayer times">
  <!-- skeleton tiles while loading -->
  <div id="prayer-list-loading" class="grid grid-cols-1 sm:grid-cols-6 gap-1">
    {
      Array.from({ length: 6 }).map(() => (
        <div class="prayer-tile">
          <div class="skeleton h-3 w-14 mb-3" />
          <div class="skeleton h-10 w-20" />
          <div class="skeleton h-2.5 w-8 mt-2" />
        </div>
      ))
    }
  </div>

  <div id="prayer-list-content" class="hidden grid-cols-1 sm:grid-cols-6 gap-1">
    <!-- populated by JS -->
  </div>
</section>

<script>
  import type { PrayerEntry } from "../scripts/prayers";
  import {
    getNextPrayer,
    getCountdownSeconds,
    formatCountdown,
  } from "../scripts/prayers";

  /** Convert #rrggbb to rgba(...) */
  function hexToRgba(hex: string, alpha: number): string {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
  }

  function render(prayers: PrayerEntry[], nowSec: number) {
    const loading = document.getElementById("prayer-list-loading");
    const content = document.getElementById("prayer-list-content");
    if (!loading || !content) return;

    const passed = prayers.filter((p) => p.ts <= nowSec);
    const currentKey = passed.length > 0 ? passed[passed.length - 1].key : null;

    content.innerHTML = "";

    for (const prayer of prayers) {
      const isActive = prayer.key === currentKey;
      const isPast = prayer.ts < nowSec && !isActive;

      const tile = document.createElement("div");
      tile.className = `prayer-tile${isActive ? " prayer-tile-active" : ""}`;

      const d = new Date(prayer.ts * 1000);
      let h = d.getHours();
      const m = String(d.getMinutes()).padStart(2, "0");
      const ampm = h >= 12 ? "PM" : "AM";
      h = h % 12 || 12;

      if (isActive) {
        const next = getNextPrayer(prayers, nowSec);
        const countdown = next
          ? formatCountdown(getCountdownSeconds(next, nowSec))
          : "N/A";
        const towardLabel = next ? `KE ${next.name.toUpperCase()}` : "SELESAI";

        tile.style.background = prayer.color;
        tile.style.color = "#ffffff";
        tile.innerHTML = `
          <div class="prayer-tile-main">
            <span class="prayer-name" style="font-size:clamp(0.72rem,1.2vw,0.95rem);font-weight:700;letter-spacing:0.18em;text-transform:uppercase;margin-bottom:0.6rem;opacity:0.88;">${prayer.name}</span>
            <span class="prayer-time" style="font-size:clamp(2rem,3.8vw,2.8rem);font-weight:300;line-height:1;letter-spacing:-0.02em;" class="tabular-nums">${h}:${m}</span>
            <span class="prayer-ampm" style="font-size:clamp(0.68rem,0.9vw,0.85rem);font-weight:700;letter-spacing:0.14em;margin-top:0.45rem;opacity:0.78;">${ampm}</span>
          </div>
          <span class="prayer-tile-divider" style="display:block;width:100%;height:1px;background:rgba(255,255,255,0.25);margin:0.8rem 0 0.65rem;"></span>
          <div class="prayer-tile-countdown">
            <span id="active-prayer-next" class="prayer-countdown-label" style="font-size:0.6rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;opacity:0.82;">${towardLabel}</span>
            <span id="active-prayer-countdown" class="prayer-countdown-time tabular-nums" style="font-size:clamp(1.05rem,1.5vw,1.35rem);font-weight:700;letter-spacing:0.03em;line-height:1.1;margin-top:0.25rem;">${countdown}</span>
          </div>
        `;
      } else {
        // Tinted background, prayer color on the name
        tile.style.background = hexToRgba(prayer.color, 0.12);
        if (isPast) tile.style.opacity = "0.4";
        tile.innerHTML = `
          <div class="prayer-tile-main">
            <span class="prayer-name" style="font-size:clamp(0.72rem,1.2vw,0.95rem);font-weight:700;letter-spacing:0.18em;text-transform:uppercase;margin-bottom:0.6rem;color:${prayer.color};">${prayer.name}</span>
            <span class="prayer-time" style="font-size:clamp(2rem,3.8vw,2.8rem);font-weight:300;line-height:1;letter-spacing:-0.02em;" class="tabular-nums">${h}:${m}</span>
            <span class="prayer-ampm" style="font-size:clamp(0.68rem,0.9vw,0.85rem);font-weight:700;letter-spacing:0.14em;margin-top:0.45rem;opacity:0.55;">${ampm}</span>
          </div>
        `;
      }

      content.appendChild(tile);
    }

    loading.classList.add("hidden");
    content.classList.remove("hidden");
    content.classList.add("grid");
  }

  function updateActiveCountdown(prayers: PrayerEntry[], nowSec: number) {
    const countdownEl = document.getElementById("active-prayer-countdown");
    const nextEl = document.getElementById("active-prayer-next");
    if (!countdownEl || !nextEl) return;

    const next = getNextPrayer(prayers, nowSec);
    if (next) {
      countdownEl.textContent = formatCountdown(
        getCountdownSeconds(next, nowSec),
      );
      nextEl.textContent = `KE ${next.name.toUpperCase()}`;
    } else {
      countdownEl.textContent = "N/A";
      nextEl.textContent = "SELESAI";
    }
  }

  function getActivePrayerKey(prayers: PrayerEntry[], nowSec: number) {
    const passed = prayers.filter((p) => p.ts <= nowSec);
    return passed.length > 0 ? passed[passed.length - 1].key : null;
  }

  let lastPrayers: PrayerEntry[] | null = null;
  let lastActiveKey: PrayerEntry["key"] | null = null;

  window.addEventListener("prayerDataLoaded", (e) => {
    const { prayers, nowSec } = (e as CustomEvent).detail;
    lastPrayers = prayers;
    lastActiveKey = getActivePrayerKey(prayers, nowSec);
    render(prayers, nowSec);
  });

  // Re-check active prayer every second so tiles flip exactly on prayer boundary.
  setInterval(() => {
    if (!lastPrayers) return;

    const nowSec = Math.floor(Date.now() / 1000);
    const activeKey = getActivePrayerKey(lastPrayers, nowSec);
    if (activeKey !== lastActiveKey) {
      lastActiveKey = activeKey;
      render(lastPrayers, nowSec);
      return;
    }

    updateActiveCountdown(lastPrayers, nowSec);
  }, 1000);
</script>
