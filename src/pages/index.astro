---
import Layout from "../layouts/Layout.astro";
import PrayerList from "../components/PrayerList.astro";
import MonthlyPrayerTable from "../components/MonthlyPrayerTable.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <main class="max-w-7xl mx-auto flex flex-col lg:h-screen">
    <!-- Error state -->
    <div
      id="page-error"
      class="hidden px-6 py-3 bg-red-600 text-white font-semibold text-sm tracking-wide text-center"
    >
    </div>

    <!-- Next prayer countdown -->
    <section
      class="px-6 py-10 lg:py-5 flex-1 flex flex-col items-center justify-center text-center"
    >
      <div
        id="live-date"
        class="mt-8 mb-12 text-(--text) font-bold text-lg sm:text-xl lg:text-5xl max-w-5xl"
      >
        N/A
      </div>

      <div class="flex flex-col items-center" aria-live="polite">
        <div
          id="next-prayer-countdown"
          class="font-light tabular-nums leading-none text-(--accent) text-center text-[clamp(4rem,15vw,9.25rem)] xl:text-[clamp(4.75rem,12vw,10.75rem)] 2xl:text-[clamp(5rem,10vw,11.75rem)] tracking-[0.04em]"
          aria-label="Countdown to next prayer"
        >
          --:--:--
        </div>
        <div
          id="next-prayer-label"
          class="mt-6 text-(--text) text-base sm:text-xl lg:text-4xl font-semibold"
        >
          Memuat waktu solat
        </div>
      </div>

      <div
        class="zone-inline-wrap max-w-5xl mt-12 w-full flex flex-col items-center"
      >
        <div class="zone-picker">
          <div
            id="zone-display"
            class="zone-display-text text-xs sm:text-sm lg:text-lg xl:text-xl font-semibold tracking-[0.08em]"
          >
            Memuat zon...
          </div>
          <select
            id="zone-select"
            class="zone-hidden-select"
            aria-label="Select prayer zone"
          >
            <option value="">Memuat zon...</option>
          </select>
        </div>

        <div class="zone-actions justify-center">
          <a href="#" id="change-location" class="zone-action-link">
            Change location
          </a>
          <a href="#" id="use-current-location" class="zone-action-link">
            Use current location
          </a>
        </div>
      </div>
    </section>

    <!-- Row 2: Prayer tiles -->
    <section class="px-6 py-10 lg:py-5 lg:mt-auto">
      <div
        class="text-xs font-semibold uppercase tracking-[0.25em] text-(--text-muted) mb-6 lg:mb-4"
      >
        Waktu Solat Hari Ini
      </div>
      <PrayerList />

      <a
        href="#monthly-timetable"
        class="mt-8 mb-4 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-(--text-muted) hover:text-(--accent) transition-colors"
        aria-label="Lihat jadual waktu solat sebulan di bawah"
      >
        <span aria-hidden="true">↓</span>
        Lihat Jadual Sebulan Di Bawah
      </a>
    </section>
  </main>

  <section
    id="monthly-timetable"
    class="max-w-7xl mx-auto px-6 py-8 border-t border-(--border)"
  >
    <MonthlyPrayerTable />
  </section>

  <Footer />
</Layout>

<script>
  import {
    fetchPrayerTimes,
    fetchPrayerTimesByGPS,
    fetchAllZones,
  } from "../scripts/api";
  import { formatHijriDate } from "../scripts/hijri";
  import {
    formatCountdown,
    getCountdownSeconds,
    getNextPrayer,
    getPrayersForDay,
  } from "../scripts/prayers";
  import type { V2Response, ZoneInfo } from "../scripts/api";
  import type { PrayerEntry } from "../scripts/prayers";

  const DEFAULT_ZONE = "WLY01";

  // State
  let currentZone = DEFAULT_ZONE;
  let monthlyData: V2Response | null = null;
  let currentPrayers: PrayerEntry[] = [];
  let lastLoadedDayKey: string | null = null;
  let rolloverTimer: number | null = null;
  let tomorrowFirstPrayer: PrayerEntry | null = null;
  let tomorrowFirstPrayerKey: string | null = null;
  let tomorrowFirstPrayerRequestKey: string | null = null;

  const gregorianFormatter = new Intl.DateTimeFormat("en-GB", {
    weekday: "long",
    day: "numeric",
    month: "long",
    year: "numeric",
  });

  function getHijriDate(now: Date): string | null {
    if (!monthlyData) return null;
    if (
      monthlyData.year !== now.getFullYear() ||
      monthlyData.month_number !== now.getMonth() + 1
    ) {
      return null;
    }

    return (
      monthlyData.prayers.find((p) => p.day === now.getDate())?.hijri ?? null
    );
  }

  function getDayKey(d: Date): string {
    return `${d.getFullYear()}-${d.getMonth() + 1}-${d.getDate()}`;
  }

  async function refreshIfDayChanged() {
    const todayKey = getDayKey(new Date());
    if (todayKey === lastLoadedDayKey) return;
    await loadData();
  }

  function scheduleNextDayRollover() {
    if (rolloverTimer !== null) window.clearTimeout(rolloverTimer);

    const now = new Date();
    const nextMidnight = new Date(
      now.getFullYear(),
      now.getMonth(),
      now.getDate() + 1,
      0,
      0,
      1,
      0,
    );
    const delayMs = Math.max(1000, nextMidnight.getTime() - now.getTime());

    rolloverTimer = window.setTimeout(async () => {
      await refreshIfDayChanged();
      scheduleNextDayRollover();
    }, delayMs);
  }

  function updateDate() {
    const now = new Date();
    const dateEl = document.getElementById("live-date");
    if (dateEl) {
      const gregorianDate = gregorianFormatter.format(now);
      const hijriDate = getHijriDate(now);
      dateEl.textContent = hijriDate
        ? `${gregorianDate} · ${formatHijriDate(hijriDate, {
            padDay: false,
            yearSuffix: "H",
          })}`
        : gregorianDate;
    }
  }

  function getTomorrow(from: Date): Date {
    return new Date(from.getFullYear(), from.getMonth(), from.getDate() + 1);
  }

  function formatPrayerTime(prayer: PrayerEntry): string {
    const d = new Date(prayer.ts * 1000);
    let h = d.getHours();
    const m = String(d.getMinutes()).padStart(2, "0");
    const ampm = h >= 12 ? "PM" : "AM";
    h = h % 12 || 12;
    return `${h}:${m} ${ampm}`;
  }

  function clearTomorrowFirstPrayer() {
    tomorrowFirstPrayer = null;
    tomorrowFirstPrayerKey = null;
    tomorrowFirstPrayerRequestKey = null;
  }

  function renderNextPrayerCountdown(
    prayer: PrayerEntry | null,
    nowSec: number,
  ) {
    const labelEl = document.getElementById("next-prayer-label");
    const countdownEl = document.getElementById("next-prayer-countdown");

    if (!labelEl || !countdownEl) return;

    if (!prayer) {
      labelEl.textContent = "Memuat waktu solat";
      countdownEl.textContent = "--:--:--";
      return;
    }

    labelEl.textContent =
      prayer === tomorrowFirstPrayer
        ? `Sebelum masuk waktu ${prayer.name} (${formatPrayerTime(prayer)})`
        : `Sebelum masuk waktu ${prayer.name}`;
    countdownEl.textContent = formatCountdown(
      getCountdownSeconds(prayer, nowSec),
    );
  }

  async function ensureTomorrowFirstPrayer(now: Date) {
    const tomorrow = getTomorrow(now);
    const tomorrowKey = `${currentZone}-${getDayKey(tomorrow)}`;

    if (tomorrowFirstPrayerKey === tomorrowKey && tomorrowFirstPrayer) return;
    if (tomorrowFirstPrayerRequestKey === tomorrowKey) return;

    tomorrowFirstPrayerRequestKey = tomorrowKey;
    const zoneAtRequest = currentZone;
    const dayKeyAtRequest = getDayKey(tomorrow);

    try {
      const data =
        monthlyData?.zone === zoneAtRequest &&
        monthlyData.year === tomorrow.getFullYear() &&
        monthlyData.month_number === tomorrow.getMonth() + 1
          ? monthlyData
          : await fetchPrayerTimes(
              zoneAtRequest,
              tomorrow.getFullYear(),
              tomorrow.getMonth() + 1,
            );
      const prayers = getPrayersForDay(data, tomorrow.getDate());
      const firstPrayer = prayers[0] ?? null;

      if (
        currentZone !== zoneAtRequest ||
        dayKeyAtRequest !== getDayKey(getTomorrow(new Date()))
      ) {
        return;
      }

      tomorrowFirstPrayer = firstPrayer;
      tomorrowFirstPrayerKey = tomorrowKey;
      updateNextPrayerCountdown();
    } catch {
      // Keep the loading state; the next interval will retry the lookup.
    } finally {
      if (tomorrowFirstPrayerRequestKey === tomorrowKey) {
        tomorrowFirstPrayerRequestKey = null;
      }
    }
  }

  function updateNextPrayerCountdown() {
    const now = new Date();
    const nowSec = Math.floor(now.getTime() / 1000);
    const nextPrayer = getNextPrayer(currentPrayers, nowSec);

    if (nextPrayer) {
      renderNextPrayerCountdown(nextPrayer, nowSec);
      return;
    }

    renderNextPrayerCountdown(tomorrowFirstPrayer, nowSec);
    void ensureTomorrowFirstPrayer(now);
  }

  // URL helpers
  function readURLParams() {
    const params = new URLSearchParams(window.location.search);
    const loc = params.get("location");
    if (loc) currentZone = loc.toUpperCase();
  }

  function pushURL() {
    const url = new URL(window.location.href);
    url.searchParams.set("location", currentZone);
    history.pushState({}, "", url);
  }

  // Data fetching
  async function loadData() {
    const today = new Date();
    const year = today.getFullYear();
    const month = today.getMonth() + 1;
    const day = today.getDate();

    try {
      monthlyData = await fetchPrayerTimes(currentZone, year, month);
    } catch (err) {
      const errEl = document.getElementById("page-error");
      if (errEl) {
        errEl.textContent =
          "Gagal memuat waktu solat. Sila semak sambungan internet anda.";
        errEl.classList.remove("hidden");
      }
      return;
    }

    const prayers = getPrayersForDay(monthlyData, day);
    const nowSec = Math.floor(Date.now() / 1000);
    currentPrayers = prayers;
    clearTomorrowFirstPrayer();

    window.dispatchEvent(
      new CustomEvent("prayerDataLoaded", {
        detail: {
          prayers,
          nowSec,
          zone: currentZone,
          monthly: monthlyData,
          day,
        },
      }),
    );

    lastLoadedDayKey = getDayKey(today);
    updateDate();
    updateNextPrayerCountdown();
  }

  // Geolocation
  function tryGeolocation(options: { fallbackToDefault?: boolean } = {}) {
    const fallbackToDefault = options.fallbackToDefault ?? true;

    if (!("geolocation" in navigator)) {
      if (fallbackToDefault) {
        resolveZone(DEFAULT_ZONE);
        void loadData();
      }
      return;
    }
    navigator.geolocation.getCurrentPosition(
      async (pos) => {
        const { latitude, longitude } = pos.coords;
        try {
          const today = new Date();
          const year = today.getFullYear();
          const month = today.getMonth() + 1;
          const gpsData = await fetchPrayerTimesByGPS(
            latitude,
            longitude,
            year,
            month,
          );
          currentZone = gpsData.zone;
          monthlyData = gpsData;
          resolveZone(currentZone);
          const day = today.getDate();
          const prayers = getPrayersForDay(gpsData, day);
          const nowSec = Math.floor(Date.now() / 1000);
          currentPrayers = prayers;
          clearTomorrowFirstPrayer();
          window.dispatchEvent(
            new CustomEvent("prayerDataLoaded", {
              detail: {
                prayers,
                nowSec,
                zone: currentZone,
                monthly: gpsData,
                day,
              },
            }),
          );
          lastLoadedDayKey = getDayKey(today);
          updateDate();
          updateNextPrayerCountdown();
          pushURL();
        } catch {
          if (fallbackToDefault) {
            resolveZone(DEFAULT_ZONE);
            await loadData();
          }
        }
      },
      () => {
        // Permission denied or error
        if (fallbackToDefault) {
          resolveZone(DEFAULT_ZONE);
          void loadData();
        }
      },
      { timeout: 8000 },
    );
  }

  function resolveZone(zone: string) {
    currentZone = zone;
    window.dispatchEvent(new CustomEvent("zoneResolved", { detail: { zone } }));
  }

  // Zone selector
  async function populateZones(selectedZone: string) {
    const select = document.getElementById(
      "zone-select",
    ) as HTMLSelectElement | null;
    if (!select) return;

    let zones: ZoneInfo[];
    try {
      zones = await fetchAllZones();
    } catch {
      select.innerHTML = `<option value="${selectedZone}">${selectedZone}</option>`;
      updateZoneDisplay();
      return;
    }

    const byState = new Map<string, ZoneInfo[]>();
    for (const z of zones) {
      if (!byState.has(z.negeri)) byState.set(z.negeri, []);
      byState.get(z.negeri)!.push(z);
    }

    select.innerHTML = "";
    for (const [state, zoneList] of byState) {
      const group = document.createElement("optgroup");
      group.label = state;

      for (const z of zoneList) {
        const opt = document.createElement("option");
        opt.value = z.jakimCode;
        opt.textContent = `${z.jakimCode} · ${z.daerah}`;
        if (z.jakimCode === selectedZone) opt.selected = true;
        group.appendChild(opt);
      }

      select.appendChild(group);
    }

    updateZoneDisplay();
  }

  function updateZoneDisplay() {
    const select = document.getElementById(
      "zone-select",
    ) as HTMLSelectElement | null;
    const display = document.getElementById("zone-display");
    if (!select || !display) return;

    const selectedText =
      select.selectedOptions[0]?.textContent?.trim() ||
      select.value ||
      "Pilih zon";
    display.textContent = selectedText;
  }

  // Event handlers
  document.getElementById("zone-select")?.addEventListener("change", (e) => {
    const zone = (e.target as HTMLSelectElement).value;
    updateZoneDisplay();
    window.dispatchEvent(new CustomEvent("zoneChanged", { detail: { zone } }));
  });

  document.getElementById("change-location")?.addEventListener("click", (e) => {
    e.preventDefault();
    const select = document.getElementById(
      "zone-select",
    ) as HTMLSelectElement | null;
    if (!select) return;

    const picker = (select as HTMLSelectElement & { showPicker?: () => void })
      .showPicker;
    if (picker) {
      try {
        picker.call(select);
        return;
      } catch {}
    }

    select.focus();
    select.click();
  });

  document
    .getElementById("use-current-location")
    ?.addEventListener("click", (e) => {
      e.preventDefault();
      tryGeolocation({ fallbackToDefault: false });
    });

  window.addEventListener("zoneResolved", async (e) => {
    const { zone } = (e as CustomEvent).detail;
    await populateZones(zone);
    const select = document.getElementById(
      "zone-select",
    ) as HTMLSelectElement | null;
    if (select) {
      select.value = zone;
      updateZoneDisplay();
    }
  });

  window.addEventListener("zoneChanged", async (e) => {
    const { zone } = (e as CustomEvent).detail;
    currentZone = zone;
    monthlyData = null;
    currentPrayers = [];
    clearTomorrowFirstPrayer();
    updateNextPrayerCountdown();
    pushURL();
    window.dispatchEvent(new CustomEvent("zoneResolved", { detail: { zone } }));
    await loadData();
  });

  // popstate (browser back/forward)
  window.addEventListener("popstate", () => {
    readURLParams();
    resolveZone(currentZone);
    void loadData();
  });

  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState !== "visible") return;
    void refreshIfDayChanged();
  });

  window.addEventListener("focus", () => {
    void refreshIfDayChanged();
  });

  // Bootstrap
  updateDate();
  updateNextPrayerCountdown();
  setInterval(() => {
    updateDate();
    updateNextPrayerCountdown();
  }, 1000);
  readURLParams();
  scheduleNextDayRollover();

  if (new URLSearchParams(window.location.search).has("location")) {
    // use currentZone from URL, skip geolocation
    resolveZone(currentZone);
    loadData();
  } else {
    // Try geolocation first
    resolveZone(DEFAULT_ZONE); // immediately show WLY01 while we wait
    loadData();
    tryGeolocation();
  }
</script>
